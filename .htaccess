<IfModule mod_rewrite.c>
    # Enable mod_rewrite engine
    RewriteEngine On
    
    # Set RewriteBase to the root of your application
    RewriteBase /iot/
    
    # Prevent direct access to sensitive files
    RewriteRule ^\.git - [F]
    RewriteRule ^\.env - [F]
    RewriteRule ^composer\.(json|lock)$ - [F]
    RewriteRule ^\.htaccess$ - [F]
    
    # Don't rewrite existing files or directories
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Rewrite clean URLs to .php files
    # Handle single-level pages: /home -> /index.php, /about -> /about.php
    RewriteRule ^([a-zA-Z0-9_-]+)/?$ $1.php [QSA,L]
    
    # Rewrite admin panel requests with clean URLs
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^admin/([a-zA-Z0-9_-]+)/?$ admin/$1.php [QSA,L]
    
    # Rewrite root request to index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^$ index.php [QSA,L]
    
</IfModule>

# Prevent direct access to PHP files via URL
<FilesMatch "\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Allow index.php access
<FilesMatch "^index\.php$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</FilesMatch>

# Prevent directory listing
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

# Set correct MIME types
<IfModule mod_mime.c>
    AddType application/javascript js
    AddType application/json json
    AddType image/svg+xml svg svgz
</IfModule>

# Cache control for static files
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
